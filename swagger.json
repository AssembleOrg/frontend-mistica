  "info": {
    "title": "Mistica Autentica API",
    "description": "API para la gestión del café bar Mistica Autentica",
    "version": "1.0",
    "contact": {}
  },
  "tags": [
    {
      "name": "Autenticación",
      "description": "Endpoints para autenticación de usuarios"
    },
    {
      "name": "Empleados",
      "description": "Gestión de empleados del café"
    },
    {
      "name": "Usuarios",
      "description": "Gestión de usuarios del sistema"
    },
    {
      "name": "Productos",
      "description": "Gestión de productos del café"
    }
  ],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "LoginUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email del usuario"
          },
          "password": {
            "type": "string",
            "description": "Contraseña del usuario"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email del usuario"
          },
          "name": {
            "type": "string",
            "description": "Nombre del usuario"
          },
          "password": {
            "type": "string",
            "description": "Contraseña del usuario"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "user"
            ],
            "description": "Rol del usuario"
          },
          "avatar": {
            "type": "string",
            "description": "Avatar del usuario"
          }
        },
        "required": [
          "email",
          "name",
          "password",
          "role"
        ]
      },
      "CreateEmployeeDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Nombre del empleado"
          },
          "email": {
            "type": "string",
            "description": "Email del empleado"
          },
          "role": {
            "type": "string",
            "enum": [
              "cajero",
              "gerente",
              "mozo"
            ],
            "description": "Rol del empleado"
          },
          "phone": {
            "type": "string",
            "description": "Teléfono del empleado"
          },
          "address": {
            "type": "string",
            "description": "Dirección del empleado"
          },
          "startDate": {
            "type": "string",
            "description": "Fecha de inicio"
          }
        },
        "required": [
          "name",
          "email",
          "role",
          "startDate"
        ]
      },
      "UpdateEmployeeDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Nombre del empleado"
          },
          "email": {
            "type": "string",
            "description": "Email del empleado"
          },
          "role": {
            "type": "string",
            "enum": [
              "cajero",
              "gerente",
              "mozo"
            ],
            "description": "Rol del empleado"
          },
          "phone": {
            "type": "string",
            "description": "Teléfono del empleado"
          },
          "address": {
            "type": "string",
            "description": "Dirección del empleado"
          },
          "startDate": {
            "type": "string",
            "description": "Fecha de inicio"
          }
        }
      },
      "UpdateUserDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "description": "Email del usuario"
          },
          "name": {
            "type": "string",
            "description": "Nombre del usuario"
          },
          "password": {
            "type": "string",
            "description": "Contraseña del usuario"
          },
          "role": {
            "type": "string",
            "enum": [
              "admin",
              "user"
            ],
            "description": "Rol del usuario"
          },
          "avatar": {
            "type": "string",
            "description": "Avatar del usuario"
          }
        }
      },
      "CreateProductDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Nombre del producto"
          },
          "barcode": {
            "type": "string",
            "description": "Código de barras del producto"
          },
          "category": {
            "type": "string",
            "enum": [
              "organicos",
              "aromaticos",
              "wellness"
            ],
            "description": "Categoría del producto"
          },
